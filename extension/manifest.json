{
  "manifest_version": 3,
  "name": "PhishGuard AI - Real-time Threat Protection",
  "version": "1.0",
  "description": "Enterprise-grade AI phishing protection for your browser.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*", "*://outlook.live.com/*"],
      "js": ["content.js"]
    }
  ]
}
